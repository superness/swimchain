# Production build config — baked into the hosted bundle at build time.
# A bare 'npm run build' without these ships a bundle that dials localhost
# and has no space configured (2026-07-16 incident). Verify after building:
#   grep -c 'swimchain.io/rpc' dist/assets/index-*.js   # must be >=1
#   grep -c 'sp1qqqsqr9dfcyugxztn5nrpjd7r82sh9cd62' dist/assets/index-*.js
VITE_RPC_ENDPOINT=https://swimchain.io/rpc
VITE_REEF_SPACE=sp1qqqsqr9dfcyugxztn5nrpjd7r82sh9cd62
