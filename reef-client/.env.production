# Production RPC endpoint — baked into the hosted bundle at build time.
# Without this, main.tsx falls back to LOCAL_TESTNET (http://127.0.0.1:19746):
# hosted visitors then hit Chrome's local-network permission prompt and
# onboarding hangs at 'Setting up your access' (2026-07-16 incident).
VITE_RPC_ENDPOINT=https://swimchain.io/rpc
