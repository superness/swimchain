# Regtest mode configuration
# Uses regtest network ports (port + 10000 offset from testnet)
# Regtest has 0.1% PoW difficulty and bypasses level checks

# RPC port for regtest genesis node (29735 + 1 = 29736)
VITE_RPC_PORT=29736

# Reduced timeouts for regtest mode (PoW is much faster)
VITE_RPC_TIMEOUT=5000
VITE_POW_TIMEOUT=10000
VITE_NAVIGATION_TIMEOUT=15000
VITE_ACTION_TIMEOUT=5000
