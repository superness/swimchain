{
  "name": "@swimchain/react",
  "version": "0.1.0",
  "description": "React hooks and components for Swimchain",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "swimchain",
    "react",
    "hooks",
    "decentralized",
    "social"
  ],
  "author": "Swimchain Contributors",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/swimchain/swimchain"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@swimchain/core": "file:../swimchain-js",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@noble/ciphers": "^0.5.0",
    "hash-wasm": "^4.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "react": "^18.2.0",
    "@testing-library/react": "^14.1.0",
    "happy-dom": "^12.10.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "sideEffects": false
}
