# ChainSocial Web Gateway Configuration
# Copy this file to .env.local and configure for your environment

# Required: Connection to a ChainSocial node
NODE_WEBSOCKET_URL=ws://localhost:9001

# Required: Public URL where this gateway is accessible
GATEWAY_PUBLIC_URL=https://read.chainsocial.io

# Optional: Rate limiting configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_SEARCH_PER_MINUTE=20

# Optional: Cache configuration (in seconds)
CACHE_MAX_AGE=300

# Optional: How far back to sync content (in hours)
SYNC_WINDOW_HOURS=168
