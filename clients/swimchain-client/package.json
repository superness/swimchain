{
  "name": "@swimchain/client",
  "version": "0.1.0",
  "description": "Portable SwimChain RPC client library for Node.js and browser",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node --test dist/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "swimchain",
    "decentralized",
    "social",
    "p2p",
    "rpc"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "hash-wasm": "^4.11.0"
  },
  "peerDependencies": {
    "@noble/ed25519": "^2.3.0"
  },
  "peerDependenciesMeta": {
    "@noble/ed25519": {
      "optional": true
    }
  }
}
